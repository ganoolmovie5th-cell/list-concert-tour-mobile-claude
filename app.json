{
  "expo": {
    "name": "ConcertID",
    "slug": "concert-id-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "id.concertid.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Diperlukan untuk upload foto dari fans dan lampiran feedback.",
        "NSPhotoLibraryAddUsageDescription": "Diperlukan untuk menyimpan foto."
      }
    },
    "android": {
      "newArchEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0a1a"
      },
      "package": "id.concertid.mobile",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "scheme": "concertid",
    "extra": {
      "eas": {
        "projectId": "b3b7d606-8fa1-4595-a5bf-f946905279e8"
      }
    }
  }
}
